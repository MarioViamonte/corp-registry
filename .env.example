# Example environment variables for local development
# Use these values to create a .env (or .env.local) in the project root.
# WARNING: Do NOT commit real secret keys to version control.

# Supabase project URL (no trailing slash)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key — NUNCA exponha a service_role no front-end
VITE_SUPABASE_KEY=your_supabase_anon_key_here

# Gemini / AI key used by geminiService (if applicable)
GEMINI_API_KEY=your_gemini_key_here
